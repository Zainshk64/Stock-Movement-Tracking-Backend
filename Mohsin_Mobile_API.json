{
  "info": {
    "name": "MohsinMobiles API",
    "description": "Complete API collection for MohsinMobiles backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Create Admin (Run Once)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@mohsinmobiles.com\",\n  \"password\": \"admin123\",\n  \"adminSecret\": \"MOHSIN_ADMIN_2024\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/create-admin",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "create-admin"]
            }
          }
        },
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "signup"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@mohsinmobiles.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Updated\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Get Products with Filters",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?category=Smartphones&minPrice=50000&maxPrice=200000&sort=price_asc&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "category", "value": "Smartphones" },
                { "key": "minPrice", "value": "50000" },
                { "key": "maxPrice", "value": "200000" },
                { "key": "sort", "value": "price_asc" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?search=iPhone",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [{ "key": "search", "value": "iPhone" }]
            }
          }
        },
        {
          "name": "Get Featured Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/featured",
              "host": ["{{baseUrl}}"],
              "path": ["products", "featured"]
            }
          }
        },
        {
          "name": "Get Single Product",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":id"],
              "variable": [
                { "key": "id", "value": "PRODUCT_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Get All Products (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/admin/all",
              "host": ["{{baseUrl}}"],
              "path": ["products", "admin", "all"]
            }
          }
        },
        {
          "name": "Get Low Stock Products",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/admin/low-stock",
              "host": ["{{baseUrl}}"],
              "path": ["products", "admin", "low-stock"]
            }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15 Pro Max\",\n  \"brand\": \"Apple\",\n  \"category\": \"Smartphones\",\n  \"price\": 159900,\n  \"originalPrice\": 169900,\n  \"stock\": 12,\n  \"description\": \"The most powerful iPhone ever with A17 Pro chip\",\n  \"image\": \"https://example.com/iphone15.jpg\",\n  \"featured\": true,\n  \"specifications\": {\n    \"Display\": \"6.7 inch Super Retina XDR\",\n    \"Processor\": \"A17 Pro Bionic\",\n    \"RAM\": \"8 GB\",\n    \"Storage\": \"256 GB\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 149900,\n  \"stock\": 15,\n  \"featured\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":id"],
              "variable": [
                { "key": "id", "value": "PRODUCT_ID_HERE" }
              ]
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/:id",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":id"],
              "variable": [
                { "key": "id", "value": "PRODUCT_ID_HERE" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Stock",
      "item": [
        {
          "name": "Get Stock Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stock",
              "host": ["{{baseUrl}}"],
              "path": ["stock"]
            }
          }
        },
        {
          "name": "Get Stock Logs with Filters",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stock?type=transferred&settled=false",
              "host": ["{{baseUrl}}"],
              "path": ["stock"],
              "query": [
                { "key": "type", "value": "transferred" },
                { "key": "settled", "value": "false" }
              ]
            }
          }
        },
        {
          "name": "Get Stock Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stock/stats",
              "host": ["{{baseUrl}}"],
              "path": ["stock", "stats"]
            }
          }
        },
        {
          "name": "Get Unsettled Transfers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stock/unsettled",
              "host": ["{{baseUrl}}"],
              "path": ["stock", "unsettled"]
            }
          }
        },
        {
          "name": "Add Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 20,\n  \"reference\": \"PO-2024-001\",\n  \"notes\": \"Initial stock from Apple distributor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stock/add",
              "host": ["{{baseUrl}}"],
              "path": ["stock", "add"]
            }
          }
        },
        {
          "name": "Record Sale (Stock Sold)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 2,\n  \"reference\": \"INV-001\",\n  \"notes\": \"Walk-in customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stock/sold",
              "host": ["{{baseUrl}}"],
              "path": ["stock", "sold"]
            }
          }
        },
        {
          "name": "Transfer Stock",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 5,\n  \"person\": \"City Mobile Store\",\n  \"reference\": \"TRF-001\",\n  \"notes\": \"Given on credit\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/stock/transfer",
              "host": ["{{baseUrl}}"],
              "path": ["stock", "transfer"]
            }
          }
        },
        {
          "name": "Settle Transfer",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/stock/:id/settle",
              "host": ["{{baseUrl}}"],
              "path": ["stock", ":id", "settle"],
              "variable": [
                { "key": "id", "value": "STOCK_LOG_ID_HERE" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Get All Sales",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sales",
              "host": ["{{baseUrl}}"],
              "path": ["sales"]
            }
          }
        },
        {
          "name": "Get Sales with Filters",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sales?startDate=2024-01-01&endDate=2024-12-31&customer=Walk-in",
              "host": ["{{baseUrl}}"],
              "path": ["sales"],
              "query": [
                { "key": "startDate", "value": "2024-01-01" },
                { "key": "endDate", "value": "2024-12-31" },
                { "key": "customer", "value": "Walk-in" }
              ]
            }
          }
        },
        {
          "name": "Get Sales Reports",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sales/reports?period=monthly",
              "host": ["{{baseUrl}}"],
              "path": ["sales", "reports"],
              "query": [
                { "key": "period", "value": "monthly" }
              ]
            }
          }
        },
        {
          "name": "Get Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/sales/dashboard",
              "host": ["{{baseUrl}}"],
              "path": ["sales", "dashboard"]
            }
          }
        },
        {
          "name": "Create Sale",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PRODUCT_ID_HERE\",\n  \"quantity\": 1,\n  \"customer\": \"Rahul Sharma\",\n  \"paymentMethod\": \"cash\",\n  \"notes\": \"Regular customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/sales",
              "host": ["{{baseUrl}}"],
              "path": ["sales"]
            }
          }
        }
      ]
    }
  ]
}